<Window
    x:Class="AirPlayer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirPlayer.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AirPlayer Receiver">

    <!-- 主网格，带有极具质感的深色背景 -->
    <Grid x:Name="MainGrid" Background="#090811">
        <Grid.Resources>
            <!-- 等待连接界面的极简脉动呼吸光晕动画 -->
            <Storyboard x:Name="PulseStoryboard" RepeatBehavior="Forever">
                <!-- 渐变阴影的透明度渐变 -->
                <DoubleAnimation
                    Storyboard.TargetName="PulseGlow"
                    Storyboard.TargetProperty="Opacity"
                    From="0.15" To="0.45" Duration="0:0:3"
                    AutoReverse="True"/>
                <!-- 水平缩放动画 -->
                <DoubleAnimation
                    Storyboard.TargetName="GlowScaleTransform"
                    Storyboard.TargetProperty="ScaleX"
                    From="0.9" To="1.1" Duration="0:0:3"
                    AutoReverse="True"/>
                <!-- 垂直缩放动画 -->
                <DoubleAnimation
                    Storyboard.TargetName="GlowScaleTransform"
                    Storyboard.TargetProperty="ScaleY"
                    From="0.9" To="1.1" Duration="0:0:3"
                    AutoReverse="True"/>
            </Storyboard>
        </Grid.Resources>
        
        <!-- 视频显示容器（原生 SwapChainPanel，全 GPU 管线呈现），投屏开启时显示 -->
        <SwapChainPanel
            x:Name="SwapPanel"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Visibility="Collapsed"/>

        <!-- 极简高端配对引导层，在无投屏信号时显示 -->
        <Grid x:Name="PromoGrid" Visibility="Visible">
            
            <!-- 紫色呼吸光晕径向渐变，提升纯黑屏单调感 -->
            <Ellipse x:Name="PulseGlow" Width="600" Height="600" Opacity="0.2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <!-- 中心高亮紫色 -->
                        <GradientStop Color="#7C4DFF" Offset="0"/>
                        <!-- 边缘完全透明 -->
                        <GradientStop Color="#007C4DFF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <!-- 动画中心原点缩放 -->
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="GlowScaleTransform" CenterX="300" CenterY="300" ScaleX="1" ScaleY="1"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- 垂直布局元素 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="25">
                
                <!-- 漂亮的 AirPlayer 应用 LOGO 图像 -->
                <Image Source="Assets/AppIcon.png" Width="96" Height="96" HorizontalAlignment="Center"/>
                
                <!-- 主状态文案 -->
                <TextBlock 
                    x:Name="StatusTitle" 
                    Text="准备就绪" 
                    FontSize="28" 
                    FontWeight="Bold" 
                    Foreground="White" 
                    HorizontalAlignment="Center"
                    FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei"/>

                <!-- 副状态文案 -->
                <TextBlock 
                    x:Name="StatusSubtitle" 
                    Text="在 iOS 设备上拉下控制中心，点击「屏幕镜像」投屏" 
                    FontSize="16" 
                    Foreground="#A0A0C0" 
                    HorizontalAlignment="Center"
                    FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei"/>

                <!-- 磨砂边缘设备名称提示牌 -->
                <Border Background="#1A1530" CornerRadius="12" Padding="24,14" HorizontalAlignment="Center" BorderBrush="#302550" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="设备名称：" Foreground="#8080A0" FontSize="14" FontFamily="Segoe UI Variable, Microsoft YaHei"/>
                        <!-- 连接设备绿字突出 -->
                        <TextBlock x:Name="DeviceNameText" Text="AirPlayer" Foreground="#00E676" FontWeight="SemiBold" FontSize="14" FontFamily="Segoe UI Variable, Microsoft YaHei"/>
                    </StackPanel>
                </Border>

                <!-- 本机局域网 IP，方便确认在同一网络 -->
                <TextBlock x:Name="IpText" Text="" Foreground="#6868A0" FontSize="13" HorizontalAlignment="Center" FontFamily="Segoe UI Variable, Microsoft YaHei"/>
            </StackPanel>
        </Grid>
        
        <!-- 左上角实时 HUD（默认隐藏，可在设置或按 H 切换）-->
        <Border x:Name="HudPanel"
                Visibility="Collapsed"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="20"
                Background="#90000000"
                CornerRadius="8"
                Padding="12,8">
            <TextBlock x:Name="HudText"
                       Foreground="#00E676"
                       FontFamily="Consolas, Cascadia Mono"
                       FontSize="13"
                       Text="HUD"/>
        </Border>

        <!-- 右上角单一菜单按钮（鼠标空闲时自动隐藏），所有功能收进子菜单，界面更干净 -->
        <Button
            x:Name="MenuButton"
            VerticalAlignment="Top"
            HorizontalAlignment="Right"
            Margin="20"
            Content="&#xE712;"
            FontFamily="Segoe MDL2 Assets"
            FontSize="18"
            Foreground="White"
            Background="#30000000"
            BorderThickness="0"
            Width="40"
            Height="40"
            CornerRadius="20"
            ToolTipService.ToolTip="菜单">
            <Button.Flyout>
                <MenuFlyout x:Name="MainMenuFlyout"
                            Placement="BottomEdgeAlignedRight"
                            Opening="MainMenuFlyout_Opening"
                            Opened="MainMenuFlyout_Opened"
                            Closed="MainMenuFlyout_Closed">
                    <MenuFlyoutItem x:Name="ScreenshotMenuItem" Text="截图 (S)" Click="ScreenshotButton_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE722;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>

                    <MenuFlyoutItem x:Name="RotateMenuItem" Text="旋转画面 (R)" Click="RotateButton_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE777;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <ToggleMenuFlyoutItem x:Name="FillScreenMenuItem" Text="铺满屏幕" Click="FillScreenMenuItem_Click">
                        <ToggleMenuFlyoutItem.Icon><FontIcon Glyph="&#xE740;"/></ToggleMenuFlyoutItem.Icon>
                    </ToggleMenuFlyoutItem>
                    <MenuFlyoutItem x:Name="FullScreenMenuItem" Text="切换全屏 (F11)" Click="FullScreenButton_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE740;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="ExitMirroringMenuItem" Text="退出投屏 (Q)" Click="ExitMirroringMenuItem_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE711;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator x:Name="ActiveCastingSeparator"/>
                    <ToggleMenuFlyoutItem x:Name="HudMenuItem" Text="显示 HUD (H)" Click="HudMenuItem_Click">
                        <ToggleMenuFlyoutItem.Icon><FontIcon Glyph="&#xE9D9;"/></ToggleMenuFlyoutItem.Icon>
                    </ToggleMenuFlyoutItem>
                    <ToggleMenuFlyoutItem x:Name="AlwaysOnTopMenuItem" Text="窗口置顶 (T)" Click="AlwaysOnTopMenuItem_Click">
                        <ToggleMenuFlyoutItem.Icon><FontIcon Glyph="&#xE718;"/></ToggleMenuFlyoutItem.Icon>
                    </ToggleMenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="更多设置…" Click="SettingsMenuItem_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Button.Flyout>
        </Button>

        <!-- 底部居中的瞬时提示（截图等操作反馈）-->
        <Border x:Name="ToastPanel"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,48"
                Background="#CC1A1530"
                BorderBrush="#302550"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18,10">
            <TextBlock x:Name="ToastText" Foreground="White" FontSize="14"
                       FontFamily="Segoe UI Variable, Microsoft YaHei"/>
        </Border>
    </Grid>
</Window>
